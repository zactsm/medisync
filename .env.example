APP_NAME=MediSync
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kuala_Lumpur
APP_URL=http://medisync.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Database Configuration (PostgreSQL for Supabase in production / Laragon PostgreSQL local)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=medisync
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SSLMODE=prefer

# Alternative for Local SQLite fallback if PostgreSQL service is stopped:
# DB_CONNECTION=sqlite

# Supabase Production Database Credentials (Vercel deployment)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Vercel Configuration
VERCEL_ENV=development

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

VITE_APP_NAME="${APP_NAME}"
VITE_SUPABASE_URL="${SUPABASE_URL}"
VITE_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"

# Supabase Storage (server-side only; never expose these in VITE_ variables)
SUPABASE_STORAGE_KEY=
SUPABASE_STORAGE_SECRET=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=medical-documents
SUPABASE_STORAGE_ENDPOINT=
GOOGLE_MAPS_API_KEY=
SMS_PROVIDER=log
